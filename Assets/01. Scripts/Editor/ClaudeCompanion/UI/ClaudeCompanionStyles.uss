/* M2 visual identity pass: warm dark neutrals + a terracotta brand accent, replacing the
   cool-gray placeholder palette M1 ported 1:1 from the old IMGUI colors. Session identity
   (accent stripe/bar) and hover/focus/active microinteractions live here too - state colors
   (busy/idle/running/stopped) stay semantic and are NOT part of this pass, see
   CharacterStageElement.cs / ClaudeCompanionWindow's Running/Stopped/Busy/Idle constants. */

.root {
    flex-grow: 1;
    background-color: rgb(26, 24, 23);
}

.main-row {
    flex-grow: 1;
    flex-direction: row;
}

.sidebar {
    width: 150px;
    flex-shrink: 0;
    padding: 4px;
}

.sidebar-title {
    -unity-font-style: bold;
    font-size: 12px;
    color: rgb(230, 227, 224);
    margin-bottom: 4px;
}

.vertical-divider {
    width: 1px;
    background-color: rgba(255, 255, 255, 0.08);
    margin-left: 4px;
    margin-right: 4px;
}

.horizontal-divider {
    height: 1px;
    background-color: rgba(255, 255, 255, 0.08);
    margin-top: 6px;
    margin-bottom: 6px;
}

.session-row {
    flex-direction: row;
    align-items: center;
    height: 24px;
    border-radius: 4px;
    margin-bottom: 2px;
    border-left-width: 3px;
    border-left-color: rgba(0, 0, 0, 0);
    transition-property: background-color;
    transition-duration: 120ms;
}

.session-row:hover {
    background-color: rgba(255, 255, 255, 0.05);
}

.session-row--active {
    background-color: rgba(255, 255, 255, 0.07);
}

.session-row--active:hover {
    background-color: rgba(255, 255, 255, 0.10);
}

/* C안(리치 디테일): 활성 세션에 좌측 accent 스트라이프(인라인) + 은은한 링 테두리 */
.session-row--active {
    border-top-width: 1px;
    border-right-width: 1px;
    border-bottom-width: 1px;
    border-top-color: rgba(255, 255, 255, 0.15);
    border-right-color: rgba(255, 255, 255, 0.15);
    border-bottom-color: rgba(255, 255, 255, 0.15);
}

.session-unseen-badge {
    width: 6px;
    height: 6px;
    border-radius: 3px;
    background-color: rgb(230, 181, 90);
    margin-right: 4px;
}

.session-rename-field {
    flex-grow: 1;
    margin: 0;
}

.session-dot {
    width: 8px;
    height: 8px;
    border-radius: 4px;
    margin-left: 4px;
    margin-right: 6px;
}

.session-label {
    flex-grow: 1;
    color: rgb(197, 191, 186);
    -unity-text-align: middle-left;
}

.session-label--active {
    color: rgb(255, 255, 255);
    -unity-font-style: bold;
}

.session-delete-button {
    width: 18px;
    transition-property: background-color;
    transition-duration: 120ms;
}

.session-delete-button:hover {
    background-color: rgba(217, 89, 89, 0.35);
}

.new-session-button {
    height: 22px;
    margin-top: 4px;
}

.main-column {
    flex-grow: 1;
    padding-left: 6px;
    padding-right: 6px;
    padding-top: 4px;
}

.empty-state-label {
    flex-grow: 1;
    -unity-text-align: middle-center;
    color: rgb(230, 227, 224);
    font-size: 12px;
}

.session-accent-bar {
    height: 3px;
    border-radius: 2px;
    margin-bottom: 6px;
    transition-property: background-color;
    transition-duration: 200ms;
}

.character-stage {
    height: 132px;
    background-color: rgb(35, 32, 31);
    position: relative;
    margin-bottom: 6px;
    border-radius: 6px;
    border-top-width: 1px;
    border-top-color: rgba(255, 255, 255, 0.06);
    /* The halo glow is deliberately larger than the body and can extend past the panel edges -
       without this it visibly "leaked" outside the rounded card (user report, 2026-07-16). */
    overflow: hidden;
    transition-property: height;
    transition-duration: 180ms;
}

/* "B" direction (2026-07-16): compact by default, taller + backdrop image when toggled - see
   CharacterStageElement.Expanded. */
.character-stage--expanded {
    height: 240px;
}

.stage-room-backdrop {
    position: absolute;
    left: 0;
    top: 0;
    -unity-background-scale-mode: scale-and-crop;
}

.stage-expand-button {
    position: absolute;
    top: 4px;
    right: 4px;
    width: 62px;
    height: 18px;
    font-size: 9px;
    padding: 0;
    background-color: rgba(0, 0, 0, 0.35);
    color: rgb(230, 227, 224);
}

.stage-expand-button:hover {
    background-color: rgba(0, 0, 0, 0.55);
}

.stage-circle {
    position: absolute;
    border-radius: 50%;
}

.stage-ground-shadow {
    position: absolute;
    border-radius: 50%;
    background-color: rgba(0, 0, 0, 0.28);
}

.stage-body-shine {
    position: absolute;
    border-radius: 50%;
    background-color: rgb(255, 255, 255);
}

/* C안: 캐릭터 뒤 은은한 halo(오라) + 몸 주위를 도는 다색 링. 배경 투명, 테두리만 보임. */
.stage-ring {
    position: absolute;
    border-radius: 50%;
    border-width: 2px;
    background-color: rgba(0, 0, 0, 0);
}

.stage-mouth {
    position: absolute;
    border-radius: 50%;
}

.stage-glasses-lens {
    position: absolute;
    border-radius: 50%;
    border-width: 1.5px;
    border-color: rgba(30, 27, 25, 0.9);
    background-color: rgba(255, 255, 255, 0.05);
}

.stage-glasses-bridge {
    position: absolute;
    height: 1.5px;
    background-color: rgba(30, 27, 25, 0.9);
}

/* "Personal space" set dressing - flat desk/monitor/plant, see CharacterStageElement's
   constructor comment for why this is deliberately light instead of the reference room art. */
.stage-desk {
    position: absolute;
    height: 7px;
    border-radius: 2px;
}

.stage-monitor-body {
    position: absolute;
    width: 42px;
    height: 32px;
    border-radius: 3px;
}

.stage-monitor-screen {
    position: absolute;
    width: 34px;
    height: 24px;
    border-radius: 1px;
}

.stage-monitor-stand {
    position: absolute;
    border-radius: 1px;
}

.stage-monitor-base {
    position: absolute;
    border-radius: 2px;
}

.stage-keyboard {
    position: absolute;
    border-radius: 1px;
}

.stage-mug {
    position: absolute;
    border-radius: 2px;
}

.stage-book {
    position: absolute;
    width: 14px;
    height: 10px;
    border-radius: 1px;
    background-color: rgb(196, 92, 78);
}

.stage-loader-ring {
    position: absolute;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    border-width: 2px;
    border-color: rgb(255, 230, 210);
    border-top-color: rgba(0, 0, 0, 0);
    background-color: rgba(0, 0, 0, 0);
}

.stage-code-line {
    position: absolute;
    height: 2px;
    border-radius: 1px;
    background-color: rgba(255, 255, 255, 0.55);
}

.stage-sparkle {
    position: absolute;
    font-size: 12px;
    color: rgb(255, 224, 130);
    -unity-text-align: middle-center;
}

.stage-sweat-drop {
    position: absolute;
    background-color: rgb(120, 190, 230);
}

.stage-plant-pot {
    position: absolute;
    width: 16px;
    height: 10px;
    border-radius: 2px;
}

.stage-plant-leaf {
    position: absolute;
    border-radius: 50%;
}

.stage-thought-bubble {
    position: absolute;
    border-radius: 50%;
    border-width: 1px;
    border-color: rgba(255, 255, 255, 0.4);
    background-color: rgba(255, 255, 255, 0.18);
}

.stage-thought-tail {
    position: absolute;
    border-radius: 50%;
    border-width: 1px;
    border-color: rgba(255, 255, 255, 0.35);
    background-color: rgba(255, 255, 255, 0.16);
}

.stage-thought-dot {
    position: absolute;
    border-radius: 50%;
    background-color: rgba(255, 255, 255, 0.8);
}

.stage-state-label {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 16px;
    -unity-text-align: middle-center;
    font-size: 10px;
    color: rgb(214, 209, 204);
}

.controls-row {
    flex-direction: row;
    align-items: center;
    margin-bottom: 4px;
}

.stepper-section {
    margin-bottom: 6px;
    background-color: rgb(32, 29, 28);
    border-radius: 6px;
    border-top-width: 1px;
    border-top-color: rgba(255, 255, 255, 0.06);
    padding: 5px 6px 3px;
}

.stepper-header {
    flex-direction: row;
    align-items: center;
    margin-bottom: 3px;
}

.stepper-title {
    -unity-font-style: bold;
    font-size: 11px;
    color: rgb(197, 191, 186);
}

.stepper-toggle-button {
    width: 70px;
    height: 18px;
    font-size: 10px;
}

.stepper-scroll {
    max-height: 64px;
}

.stepper-content {
    flex-direction: row;
    flex-wrap: wrap;
}

.stepper-placeholder {
    font-size: 10px;
    color: rgb(120, 114, 109);
}

.step-chip {
    flex-direction: row;
    align-items: center;
    background-color: rgba(255, 255, 255, 0.08);
    border-radius: 10px;
    border-width: 1px;
    padding: 2px 8px 2px 6px;
    margin-right: 4px;
    margin-bottom: 4px;
}

.step-chip-icon {
    font-size: 10px;
    margin-right: 5px;
}

.step-chip-label {
    font-size: 10px;
    color: rgb(214, 209, 204);
}

.bridge-toggle-button {
    width: 90px;
    height: 24px;
    color: rgb(255, 255, 255);
    transition-property: background-color, scale;
    transition-duration: 120ms;
}

.bridge-toggle-button:active {
    scale: 0.96;
}

.bridge-toggle-button--running {
    background-color: rgb(196, 82, 82);
}

.bridge-toggle-button--running:hover {
    background-color: rgb(214, 98, 98);
}

.bridge-toggle-button--stopped {
    background-color: rgb(84, 158, 105);
}

.bridge-toggle-button--stopped:hover {
    background-color: rgb(98, 176, 120);
}

.bridge-dot {
    width: 12px;
    height: 12px;
    border-radius: 6px;
    margin-left: 6px;
    margin-right: 6px;
}

.bridge-label {
    width: 90px;
    font-size: 10px;
    color: rgb(197, 191, 186);
}

.spacer {
    flex-grow: 1;
}

.fallback-input-button {
    width: 80px;
    transition-property: background-color;
    transition-duration: 120ms;
}

.settings-button {
    width: 60px;
    margin-right: 4px;
    transition-property: background-color;
    transition-duration: 120ms;
}

.typing-indicator {
    flex-direction: row;
    align-items: center;
    padding: 8px 10px;
}

.typing-dot {
    width: 6px;
    height: 6px;
    border-radius: 3px;
    background-color: rgb(214, 209, 204);
    margin-right: 4px;
}

.chat-area {
    flex-grow: 1;
    min-height: 0;
    background-color: rgb(32, 29, 28);
    border-radius: 6px;
    border-top-width: 1px;
    border-top-color: rgba(255, 255, 255, 0.06);
    padding: 6px;
}

.chat-header-row {
    flex-direction: row;
    align-items: center;
    flex-shrink: 0;
    margin-bottom: 4px;
}

.chat-search-field {
    width: 120px;
    height: 18px;
    margin: 0 4px 0 0;
}

.chat-search-field-inner {
    background-color: rgb(62, 58, 57);
    color: rgb(255, 255, 255);
    font-size: 10px;
    padding: 2px 5px;
    border-radius: 3px;
    border-left-width: 0;
    border-right-width: 0;
    border-top-width: 0;
    border-bottom-width: 0;
}

.chat-export-button {
    width: 60px;
    height: 18px;
    font-size: 10px;
}

.chat-no-results-label {
    font-size: 10px;
    color: rgb(120, 114, 109);
    padding: 6px 0;
}

.chat-scroll {
    flex-grow: 1;
    /* Without this, a flex-grow child defaults to a min-height based on its own content (the
       whole chat history) instead of shrinking to fit the space actually available - the
       symptom was the input row/Send button getting pushed below the window's visible bounds
       as the conversation grew (user report, 2026-07-16). This is what lets it actually
       shrink and rely on ScrollView's own internal scrolling instead. */
    min-height: 0;
}

.chat-bubble-row {
    flex-direction: row;
    margin-bottom: 4px;
}

.chat-bubble-row--user {
    justify-content: flex-end;
}

.chat-bubble-row--claude {
    justify-content: flex-start;
}

.chat-bubble {
    max-width: 85%;
    border-radius: 6px;
    padding: 3px 6px;
    position: relative;
    transition-property: opacity;
    transition-duration: 150ms;
}

.bubble-copy-button {
    position: absolute;
    top: 2px;
    right: 2px;
    width: 18px;
    height: 18px;
    padding: 0;
    font-size: 10px;
    background-color: rgba(0, 0, 0, 0.28);
    color: rgb(255, 255, 255);
    opacity: 0;
    transition-property: opacity;
    transition-duration: 120ms;
}

.chat-bubble:hover .bubble-copy-button {
    opacity: 1;
}

.chat-bubble--user {
    background-color: rgb(58, 91, 133);
}

.chat-bubble--claude {
    background-color: rgb(52, 48, 47);
}

.chat-bubble--pending {
    opacity: 0.5;
}

.chat-bubble-role {
    -unity-font-style: bold;
    font-size: 10px;
    color: rgb(210, 218, 232);
}

.chat-bubble-text {
    color: rgb(255, 255, 255);
    white-space: normal;
}

.chat-code-block {
    background-color: rgb(17, 16, 15);
    border-radius: 3px;
    padding: 3px 6px;
    margin-top: 2px;
    margin-bottom: 2px;
    position: relative;
}

.code-copy-button {
    position: absolute;
    top: 2px;
    right: 2px;
    width: 18px;
    height: 18px;
    padding: 0;
    font-size: 10px;
    background-color: rgba(255, 255, 255, 0.08);
    color: rgb(209, 224, 217);
    opacity: 0;
    transition-property: opacity;
    transition-duration: 120ms;
}

.chat-code-block:hover .code-copy-button {
    opacity: 1;
}

.chat-image-container {
    position: relative;
    width: 240px;
    height: 180px;
    margin-top: 2px;
    margin-bottom: 2px;
    background-color: rgb(17, 16, 15);
    border-radius: 4px;
}

.chat-image {
    width: 240px;
    height: 180px;
    border-radius: 4px;
}

.chat-image-missing {
    font-size: 10px;
    color: rgb(230, 190, 190);
    white-space: normal;
}

.image-save-button {
    position: absolute;
    bottom: 4px;
    right: 4px;
    width: 56px;
    height: 18px;
    font-size: 9px;
    padding: 0;
    background-color: rgba(0, 0, 0, 0.5);
    color: rgb(255, 255, 255);
    opacity: 0;
    transition-property: opacity;
    transition-duration: 120ms;
}

.chat-image-container:hover .image-save-button {
    opacity: 1;
}

.chat-code-text {
    color: rgb(209, 224, 217);
    font-size: 11px;
    white-space: normal;
}

.pending-count-label {
    color: rgb(150, 143, 137);
    font-size: 10px;
    margin-top: 2px;
    margin-bottom: 2px;
}

/* Wraps .chat-input so a message longer than max-height gets a mouse-wheel-scrollable
   viewport instead of just clipping - the ScrollView owns the height clamp, the TextField
   inside grows to its full natural content height (see .chat-input below). */
.chat-input-scroll {
    min-height: 24px;
    max-height: 120px;
    flex-shrink: 0;
    margin: 0;
    border-radius: 4px;
    overflow: hidden;
}

.chat-input {
    flex-shrink: 0;
    margin: 0;
    border-radius: 4px;
}

.chat-input-inner {
    background-color: rgb(52, 48, 47);
    color: rgb(255, 255, 255);
    white-space: normal;
    overflow: hidden;
    border-left-width: 0;
    border-right-width: 0;
    border-top-width: 0;
    border-bottom-width: 2px;
    border-bottom-color: rgba(0, 0, 0, 0);
    padding: 4px 6px;
    transition-property: border-bottom-color;
    transition-duration: 120ms;
}

.chat-input-inner:focus {
    border-bottom-color: rgb(217, 119, 87);
}

.chat-buttons-row {
    flex-direction: row;
    justify-content: flex-end;
    align-items: center;
    height: 28px;
    flex-shrink: 0;
    margin-top: 4px;
}

/* 2026-07-16: gray-family instead of red/green so enabled/disabled reads by brightness, not
   hue - the old coral send-button lost saturation while disabled and became easy to mistake
   for the (semantically-different) cancel-button's own muted red. */
.send-button {
    width: 64px;
    height: 24px;
    background-color: rgb(90, 90, 96);
    color: rgb(255, 255, 255);
    -unity-font-style: bold;
    transition-property: background-color, scale;
    transition-duration: 120ms;
}

.send-button:hover {
    background-color: rgb(108, 108, 114);
}

.send-button:active {
    scale: 0.96;
}

.send-button:disabled {
    background-color: rgb(42, 40, 39);
    color: rgba(255, 255, 255, 0.3);
}

/* Same gray family as send-button but a distinguishable warmer lean + a visible border while
   actually cancelable, so "can I click this right now" reads clearly at a glance instead of
   both buttons looking like an ambiguous flat gray blob. */
.cancel-button {
    width: 54px;
    height: 24px;
    margin-left: 4px;
    background-color: rgb(96, 88, 84);
    color: rgb(255, 255, 255);
    border-width: 1px;
    border-color: rgb(150, 138, 132);
    transition-property: background-color, scale;
    transition-duration: 120ms;
}

.cancel-button:hover {
    background-color: rgb(114, 104, 98);
}

.cancel-button:active {
    scale: 0.96;
}

.cancel-button:disabled {
    background-color: rgb(38, 36, 35);
    color: rgba(255, 255, 255, 0.25);
    border-color: rgba(0, 0, 0, 0);
}
