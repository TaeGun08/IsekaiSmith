/* Structural + static color styling for ClaudeCompanionWindow's UI Toolkit view.
   Values here intentionally mirror the old IMGUI palette (see ClaudeCompanionWindow's
   Color constants) so the M1 migration changes *how* the window is built, not how it looks -
   visual identity work is scoped to a later milestone. */

.root {
    flex-grow: 1;
    background-color: rgb(33, 33, 38);
}

.main-row {
    flex-grow: 1;
    flex-direction: row;
}

.sidebar {
    width: 150px;
    flex-shrink: 0;
    padding: 4px;
}

.sidebar-title {
    -unity-font-style: bold;
    font-size: 12px;
    color: rgb(230, 230, 242);
    margin-bottom: 4px;
}

.vertical-divider {
    width: 1px;
    background-color: rgba(255, 255, 255, 0.08);
    margin-left: 4px;
    margin-right: 4px;
}

.horizontal-divider {
    height: 1px;
    background-color: rgba(255, 255, 255, 0.08);
    margin-top: 6px;
    margin-bottom: 6px;
}

.session-row {
    flex-direction: row;
    align-items: center;
    height: 24px;
    border-radius: 3px;
    margin-bottom: 2px;
}

.session-row--active {
    background-color: rgba(255, 255, 255, 0.07);
}

.session-dot {
    width: 8px;
    height: 8px;
    border-radius: 4px;
    margin-left: 4px;
    margin-right: 6px;
}

.session-label {
    flex-grow: 1;
    color: rgb(191, 191, 204);
    -unity-text-align: middle-left;
}

.session-label--active {
    color: rgb(255, 255, 255);
    -unity-font-style: bold;
}

.session-delete-button {
    width: 18px;
}

.new-session-button {
    height: 22px;
    margin-top: 4px;
}

.main-column {
    flex-grow: 1;
    padding-left: 6px;
    padding-right: 6px;
    padding-top: 4px;
}

.empty-state-label {
    flex-grow: 1;
    -unity-text-align: middle-center;
    color: rgb(230, 230, 242);
    font-size: 12px;
}

.character-stage {
    height: 96px;
    background-color: rgb(43, 46, 51);
    position: relative;
    margin-bottom: 6px;
}

.stage-circle {
    position: absolute;
    border-radius: 50%;
}

.stage-state-label {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 16px;
    -unity-text-align: middle-center;
    font-size: 10px;
    color: rgb(217, 217, 230);
}

.controls-row {
    flex-direction: row;
    align-items: center;
    margin-bottom: 4px;
}

.bridge-toggle-button {
    width: 90px;
    height: 24px;
}

.bridge-dot {
    width: 12px;
    height: 12px;
    border-radius: 6px;
    margin-left: 6px;
    margin-right: 6px;
}

.bridge-label {
    width: 90px;
    font-size: 10px;
    color: rgb(191, 191, 204);
}

.spacer {
    flex-grow: 1;
}

.fallback-input-button {
    width: 80px;
}

.chat-scroll {
    flex-grow: 1;
}

.chat-bubble-row {
    flex-direction: row;
    margin-bottom: 4px;
}

.chat-bubble-row--user {
    justify-content: flex-end;
}

.chat-bubble-row--claude {
    justify-content: flex-start;
}

.chat-bubble {
    max-width: 85%;
    border-radius: 4px;
    padding: 3px 6px;
}

.chat-bubble--user {
    background-color: rgb(51, 92, 148);
}

.chat-bubble--claude {
    background-color: rgb(61, 61, 71);
}

.chat-bubble--pending {
    opacity: 0.5;
}

.chat-bubble-role {
    -unity-font-style: bold;
    font-size: 10px;
    color: rgb(204, 217, 242);
}

.chat-bubble-text {
    color: rgb(255, 255, 255);
    white-space: normal;
}

.chat-code-block {
    background-color: rgb(23, 23, 28);
    padding: 3px 6px;
    margin-top: 2px;
    margin-bottom: 2px;
}

.chat-code-text {
    color: rgb(209, 224, 217);
    font-size: 11px;
    white-space: normal;
}

.pending-count-label {
    color: rgb(140, 140, 153);
    font-size: 10px;
    margin-top: 2px;
    margin-bottom: 2px;
}

.chat-input {
    min-height: 24px;
    max-height: 120px;
    margin: 0;
}

.chat-input-inner {
    background-color: rgb(61, 61, 71);
    color: rgb(255, 255, 255);
    white-space: normal;
    overflow: hidden;
    border-left-width: 0;
    border-right-width: 0;
    border-top-width: 0;
    border-bottom-width: 0;
    padding: 4px 6px;
}

.chat-buttons-row {
    flex-direction: row;
    justify-content: flex-end;
    margin-top: 4px;
}

.send-button {
    width: 60px;
}

.cancel-button {
    width: 50px;
    margin-left: 4px;
}
